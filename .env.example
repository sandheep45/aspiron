# Server Configuration
APP_HOST=0.0.0.0
APP_PORT=8082
APP_ENV=development

AUTH_SECRET=your-secret-key-here-min-32-chars-long

AUTH_URL=http://localhost:3000/api/auth

# CORS Configuration
# Comma-separated list of allowed origins (no spaces)
CORS_ORIGINS=http://localhost:3000,http://local.aspiron.test:8082,http://local.aspiron.test:3000,https://local.aspiron.test:3000,https://localhost:3000

# IMPORTANT (React Native Development):
# If testing on a physical device, replace localhost with your machine's LAN IP.
# Example: http://192.168.1.100:8082
PUBLIC_BACKEND_URL=https://local.aspiron.test:8443

# API Version Configuration
# The API version prefix used in routes (e.g., /api/v1)
PUBLIC_ACTIVE_API_VERSION=/api/v1
# Full API base URL (used by frontend)
PUBLIC_API_BASE_URL=${PUBLIC_BACKEND_URL}${PUBLIC_ACTIVE_API_VERSION}

# LocalStack Configuration
LOCALSTACK_DOCKER_NAME="localstack-aspiron"

# S3 / LocalStack Configuration
S3_ENDPOINT=http://localhost:4566
S3_REGION=us-east-1
S3_BUCKET=aspiron-uploads
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# pgAdmin Configuration
PGADMIN_EMAIL="admin@admin.com"
PGADMIN_PASSWORD="admin@1234"

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=mint_ts
DATABASE_POOL_SIZE=10

DATABASE_URL=postgres://${DATABASE_USERNAME}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# JWT Configuration
JWT_SECRET=your-secret-key-minimum-32-characters-long
JWT_ACCESS_TOKEN_EXPIRY_SECONDS=86400
JWT_REFRESH_TOKEN_EXPIRY_SECONDS=604800
JWT_COOKIE_NAME=jwt

# Logging Configuration
# Options: json, pretty
# Optional: add sqlx query logging (e.g., LOG_LEVEL=info,sqlx::query=debug)
LOG_LEVEL=info,sea_orm::query=debug,sqlx::query=debug
LOG_FORMAT=pretty

# MeiliSearch Configuration
MEILI_MASTER_KEY=your-secret-master-key-minimum-16-characters
MEILI_HOST=http://localhost:7700
MEILI_INDEX_ENABLED=false

# Seeding Configuration
# Options: fixed, random, pattern, memorable, custom
SEED_PASSWORD_STRATEGY=fixed

# Custom Password Strategy (used when SEED_PASSWORD_STRATEGY=custom)
ADMIN_PASSWORD=admin123
TEACHER_PASSWORD=teacher123
STUDENT_PASSWORD=student123

# Pattern Strategy (used when SEED_PASSWORD_STRATEGY=pattern)
# Options: year, role, number, mixed
SEED_PATTERN_PREFIX=Aspiron
SEED_PATTERN_SUFFIX=year
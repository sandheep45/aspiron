  "components": {
    "schemas": {
      "ActionTypeEnum": {
        "type": "string",
        "enum": [
          "CREATE",
          "READ",
          "UPDATE",
          "DELETE",
          "MANAGE",
          "PUBLISH",
          "MODERATE",
          "GRADE",
          "TAKE",
          "VIEW_RESULTS",
          "VIEW_ANY_RESULTS",
          "ASSIGN_ROLES",
          "VIEW_ANALYTICS",
          "MANAGE_SETTINGS",
          "AUDIT"
        ]
      },
      "ApiResponse_AuthResponse": {
        "type": "object",
        "required": [
          "success"
        ],
        "properties": {
          "code": {
            "type": [
              "string",
              "null"
            ]
          },
          "data": {
            "type": "object",
            "required": [
              "user",
              "roles",
              "permissions"
            ],
            "properties": {
              "permissions": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/AuthPermissionResponse"
                }
              },
              "roles": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/AuthRoleResponse"
                }
              },
              "user": {
                "$ref": "#/components/schemas/AuthUserResponse"
              }
            }
          },
          "message": {
            "type": [
              "string",
              "null"
            ]
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "ApiResponse_MobileTokenResponse": {
        "type": "object",
        "required": [
          "success"
        ],
        "properties": {
          "code": {
            "type": [
              "string",
              "null"
            ]
          },
          "data": {
            "type": "object",
            "required": [
              "access_token",
              "refresh_token",
              "token_type",
              "expires_in"
            ],
            "properties": {
              "access_token": {
                "type": "string"
              },
              "expires_in": {
                "type": "integer",
                "format": "int64"
              },
              "refresh_token": {
                "type": "string"
              },
              "token_type": {
                "type": "string"
              }
            }
          },
          "message": {
            "type": [
              "string",
              "null"
            ]
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "AuthPermissionResponse": {
        "type": "object",
        "required": [
          "name",
          "resource_type",
          "action"
        ],
        "properties": {
          "action": {
            "$ref": "#/components/schemas/ActionTypeEnum"
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "name": {
            "type": "string"
          },
          "resource_type": {
            "$ref": "#/components/schemas/ResourceTypeEnum"
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "required": [
          "user",
          "roles",
          "permissions"
        ],
        "properties": {
          "permissions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuthPermissionResponse"
            }
          },
          "roles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuthRoleResponse"
            }
          },
          "user": {
            "$ref": "#/components/schemas/AuthUserResponse"
          }
        }
      },
      "AuthRoleResponse": {
        "type": "object",
        "required": [
          "name",
          "display_name",
          "is_system_role"
        ],
        "properties": {
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "display_name": {
            "type": "string"
          },
          "is_system_role": {
            "type": "boolean"
          },
          "name": {
            "$ref": "#/components/schemas/UserTypeEnums"
          }
        }
      },
      "AuthUserResponse": {
        "type": "object",
        "required": [
          "id",
          "email",
          "is_active",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "avatar_url": {
            "type": [
              "string",
              "null"
            ]
          },
          "created_at": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "first_name": {
            "type": [
              "string",
              "null"
            ]
          },
          "id": {
            "type": "string"
          },
          "is_active": {
            "type": "boolean"
          },
          "last_name": {
            "type": [
              "string",
              "null"
            ]
          },
          "updated_at": {
            "type": "string"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "status",
          "version"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "healthy"
          },
          "version": {
            "type": "string",
            "example": "0.1.0"
          }
        }
      },
      "LiveClassResponse": {
        "type": "object",
        "required": [
          "id",
          "topic_id",
          "scheduled_at",
          "duration_min",
          "provider",
          "join_url"
        ],
        "properties": {
          "duration_min": {
            "type": "integer",
            "format": "int32"
          },
          "id": {
            "type": "string"
          },
          "join_url": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "scheduled_at": {
            "type": "string"
          },
          "topic_id": {
            "type": "string"
          }
        }
      },
      "LiveClassesResponse": {
        "type": "object",
        "required": [
          "classes",
          "pagination"
        ],
        "properties": {
          "classes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LiveClassResponse"
            }
          },
          "pagination": {
            "$ref": "#/components/schemas/PaginationResponse"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "example": "barbara_turner.1@admin.aspiron"
          },
          "password": {
            "type": "string",
            "example": "admin123"
          }
        }
      },
      "MobileTokenResponse": {
        "type": "object",
        "required": [
          "access_token",
          "refresh_token",
          "token_type",
          "expires_in"
        ],
        "properties": {
          "access_token": {
            "type": "string"
          },
          "expires_in": {
            "type": "integer",
            "format": "int64"
          },
          "refresh_token": {
            "type": "string"
          },
          "token_type": {
            "type": "string"
          }
        }
      },
      "PaginationResponse": {
        "type": "object",
        "required": [
          "page",
          "limit",
          "total",
          "filtered_total",
          "total_pages"
        ],
        "properties": {
          "filtered_total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "limit": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "page": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "total": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "total_pages": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "ResourceTypeEnum": {
        "type": "string",
        "enum": [
          "USER",
          "CONTENT",
          "ASSESSMENT",
          "COMMUNITY",
          "SYSTEM",
          "SUBJECT",
          "CHAPTER",
          "TOPIC",
          "VIDEO",
          "QUIZ",
          "QUESTION",
          "THREAD",
          "POST",
          "NOTE"
        ]
      },
      "UserTypeEnums": {
        "type": "string",
        "enum": [
          "STUDENT",
          "TEACHER",
          "ADMIN"
        ]
      }
    }
  }
}
